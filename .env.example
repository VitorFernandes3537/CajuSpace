# CajuSpace — variáveis de ambiente
# Copie para .env.local (dev) e configure as mesmas na Vercel (Production).

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key   # SECRETA — nunca commitar/expor no client

# Sessão (assinatura HMAC do cookie). Gere um valor aleatório forte:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-uma-string-aleatoria-de-64-hex

# PIN global de login da equipe/admin (usado em /api/auth/login junto do email cadastrado em staff_users)
ADMIN_PIN=defina-um-pin
